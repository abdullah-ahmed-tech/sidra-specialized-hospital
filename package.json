{
  "name": "sidra-specialized-hospital",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev:website": "pnpm --filter website dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev:mobile": "pnpm --filter mobile start",
    "dev": "concurrently \"pnpm dev:website\" \"pnpm dev:admin\" \"pnpm dev:api\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.5.3"
  }
}